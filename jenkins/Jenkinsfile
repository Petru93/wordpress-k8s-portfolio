pipeline {
    agent any

    // ============================================================
    // Pipeline-wide environment variables
    // ============================================================
    environment {
        IMAGE_REGISTRY  = "ghcr.io"
        IMAGE_NAME      = "petru93/wordpress-k8s-portfolio"
        IMAGE_TAG       = "${env.BUILD_NUMBER}"
        HELM_RELEASE    = "wp-release"
        HELM_NAMESPACE  = "wordpress"
        HELM_CHART_PATH = "helm/wordpress"
    }

    // ============================================================
    // Declare shared variables at pipeline level
    // ============================================================
    options {
        disableConcurrentBuilds()
    }

    stages {

        // --------------------------------------------------------
        // Stage 1: Checkout
        // --------------------------------------------------------
        stage('Checkout') {
            steps {
                checkout scm
                echo "Building commit: ${env.GIT_COMMIT[0..7]}"
            }
        }

        // --------------------------------------------------------
        // Stage 2: Build Docker image
        // --------------------------------------------------------
        stage('Build Image') {
            steps {
                script {
                    echo "Building image: ${IMAGE_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
                    // Push happens inside withRegistry so build here too
                    docker.withRegistry(
                        "https://${IMAGE_REGISTRY}",
                        'ghcr-credentials'
                    ) {
                        dockerImage = docker.build(
                            "${IMAGE_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}",
                            "--file docker/Dockerfile ./docker"
                        )
                    }
                }
            }
        }

        // --------------------------------------------------------
        // Stage 3: Security scan with Trivy
        // --------------------------------------------------------
        stage('Trivy Scan') {
            steps {
                script {
                    echo "Scanning image for vulnerabilities..."
                    sh """
                        trivy image \
                          --exit-code 0 \
                          --severity LOW,MEDIUM \
                          --format table \
                          ${IMAGE_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}

                        trivy image \
                          --exit-code 1 \
                          --severity HIGH,CRITICAL \
                          --format table \
                          ${IMAGE_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
                    """
                }
            }
        }

        // --------------------------------------------------------
        // Stage 4: Push to GHCR
        // --------------------------------------------------------
        stage('Push Image') {
            steps {
                script {
                    docker.withRegistry(
                        "https://${IMAGE_REGISTRY}",
                        'ghcr-credentials'
                    ) {
                        dockerImage.push("${IMAGE_TAG}")
                        dockerImage.push("latest")
                        echo "Pushed: ${IMAGE_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
                        echo "Pushed: ${IMAGE_REGISTRY}/${IMAGE_NAME}:latest"
                    }
                }
            }
        }

        // --------------------------------------------------------
        // Stage 5: Deploy to k3s via Helm
        // --------------------------------------------------------
        stage('Deploy to k3s') {
            steps {
                withCredentials([
                    file(credentialsId: 'k3s-kubeconfig', variable: 'KUBECONFIG'),
                    string(credentialsId: 'mysql-root-password', variable: 'MYSQL_ROOT_PASS'),
                    string(credentialsId: 'mysql-wp-password', variable: 'MYSQL_WP_PASS')
                ]) {
                    sh """
                        helm upgrade ${HELM_RELEASE} ${HELM_CHART_PATH} \
                          --namespace ${HELM_NAMESPACE} \
                          --install \
                          --atomic \
                          --timeout 5m \
                          --set wordpress.image.repository=${IMAGE_REGISTRY}/${IMAGE_NAME} \
                          --set wordpress.image.tag=${IMAGE_TAG} \
                          --set secrets.mysqlRootPassword=\${MYSQL_ROOT_PASS} \
                          --set secrets.mysqlPassword=\${MYSQL_WP_PASS}
                    """
                }
            }
        }
    }

    // ============================================================
    // Post-pipeline actions
    // ============================================================
    post {
        success {
            echo "Pipeline succeeded — WordPress ${IMAGE_TAG} deployed to k3s"
        }
        failure {
            echo "Pipeline failed — check logs above"
        }
        always {
            sh "docker rmi ${IMAGE_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} || true"
        }
    }
}